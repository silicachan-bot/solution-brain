# ── 提取模型（必填） ──────────────────────────────────────────────────────────────
LLM_API_KEY=sk-xxx
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── 嵌入模型（必填） ──────────────────────────────────────────────────────────────
EMBED_API_KEY=sk-xxx
EMBED_API_BASE=https://api.siliconflow.cn/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-4B
EMBED_DIMENSIONS=2048

# ── 可选覆盖 ──────────────────────────────────────────────────────────────────────
# Bilibili 数据库路径（默认自动推导 monorepo 相对路径，路径不对时手动指定）
# BILIBILI_DB_PATH=/absolute/path/to/bilibili.db

# 算法参数默认值在 src/brain/config.py 中，如需临时覆盖也可写在这里，例如：
# CHUNK_SIZE=50
# MAX_CHUNKS_PER_VIDEO=5
